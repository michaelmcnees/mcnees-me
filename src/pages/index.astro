---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/base-layout.astro";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const latest = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];

// The programs on the cabinet. Each carries its own accent so the menu
// reads like a shelf of cartridges. `launch` is a URL, or "comms" for the
// SOCIAL overlay handled by the layout.
const programs = [
  { id: "about", icon: "BIO", label: "About", desc: "Operator profile & player bio", launch: "/about", accent: "#22e7ff" },
  { id: "work", icon: "WRK", label: "Work", desc: "Case studies & shipped missions", launch: "/case-studies", accent: "#f9d65c" },
  { id: "projects", icon: "PRJ", label: "Projects", desc: "Side-quest builds & experiments", launch: "/projects", accent: "#58ff9b" },
  { id: "blog", icon: "LOG", label: "Blog", desc: "Transmission log & field notes", launch: "/blog", accent: "#ff2bd6" },
  { id: "social", icon: "NET", label: "Social", desc: "Comms uplink — email, GitHub, GitLab", launch: "comms", accent: "#8a4cff" },
];
---
<BaseLayout title="Michael McNees // MCNEES.OS" app="menu">
  <section class="menu-screen">
    <div class="menu-head">
      <div class="menu-kicker">★ PLAYER 1 — MICHAEL McNEES ★</div>
      <h1 class="menu-title">Select Program</h1>
      <p class="menu-sub">Engineering manager · builder · writer — West Michigan, USA</p>
    </div>

    <ul class="menu-list" id="menu-list">
      {programs.map((p, i) => (
        <li>
          <a
            class:list={["menu-item", i === 0 && "selected"]}
            style={`--ia: ${p.accent}`}
            href={p.launch === "comms" ? "#" : p.launch}
            data-launch={p.launch}
            data-index={i}
          >
            <span class="menu-sel" aria-hidden="true">▶</span>
            <span class="menu-icon" aria-hidden="true">{p.icon}</span>
            <span class="menu-text">
              <span class="menu-label">{p.label}</span>
              <span class="menu-desc">{p.desc}</span>
            </span>
            <span class="menu-chev">PRESS&nbsp;⏎</span>
          </a>
        </li>
      ))}
    </ul>

    <div class="menu-foot">
      <span class="menu-coin">● INSERT COIN</span>
      {latest && (
        <span class="menu-ticker">
          NOW PLAYING: <a href={`/blog/${latest.id}`}>{latest.data.title}</a>
        </span>
      )}
      <span class="menu-hint">
        <kbd>↑</kbd><kbd>↓</kbd> SELECT · <kbd>⏎</kbd> LAUNCH
      </span>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    const list = document.getElementById("menu-list");
    if (!list) return;
    const items = Array.from(list.querySelectorAll(".menu-item"));
    if (!items.length) return;
    let sel = items.findIndex((el) => el.classList.contains("selected"));
    if (sel < 0) sel = 0;

    function select(next) {
      sel = (next + items.length) % items.length;
      items.forEach((el, i) => el.classList.toggle("selected", i === sel));
      items[sel].focus({ preventScroll: false });
    }

    function launch(el) {
      const target = el.getAttribute("data-launch");
      if (target === "comms") {
        const btn = document.querySelector("[data-comms-open]");
        if (btn) btn.click();
        return;
      }
      // Quick screen fade, then navigate — the destination plays its own
      // boot splash, so the launch feels continuous.
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduce) { window.location.href = target; return; }
      document.body.style.transition = "opacity .2s ease";
      document.body.style.opacity = "0.35";
      setTimeout(() => { window.location.href = target; }, 170);
    }

    // Pointer: hover tracks selection; click launches (comms intercepts).
    items.forEach((el, i) => {
      el.addEventListener("mouseenter", () => {
        sel = i;
        items.forEach((x, j) => x.classList.toggle("selected", j === i));
      });
      el.addEventListener("click", (e) => {
        if (el.getAttribute("data-launch") === "comms") {
          e.preventDefault();
          launch(el);
        }
        // real URLs fall through to the anchor + fade handled below
      });
    });

    // Keyboard: arrows move, Enter launches the highlighted program.
    document.addEventListener("keydown", (e) => {
      const t = e.target;
      if (t && (t.tagName === "INPUT" || t.tagName === "TEXTAREA" || t.isContentEditable)) return;
      if (e.key === "ArrowDown" || e.key === "ArrowRight") { e.preventDefault(); select(sel + 1); }
      else if (e.key === "ArrowUp" || e.key === "ArrowLeft") { e.preventDefault(); select(sel - 1); }
      else if (e.key === "Enter" && (!t || !t.classList || !t.classList.contains("menu-item"))) {
        e.preventDefault();
        launch(items[sel]);
      }
    });

    // Anchor click on real programs → fade transition.
    items.forEach((el) => {
      if (el.getAttribute("data-launch") !== "comms") {
        el.addEventListener("click", (e) => {
          if (e.metaKey || e.ctrlKey || e.shiftKey) return; // let new-tab through
          e.preventDefault();
          launch(el);
        });
      }
    });
  })();
</script>
