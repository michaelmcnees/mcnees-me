---
// Radial darkening vignette at the edges.
---
<div class="sw-vignette" aria-hidden="true"></div>

<style>
  .sw-vignette {
    position: fixed;
    inset: 0;
    z-index: 49;
    pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 55%, rgba(0,0,0,0.55) 100%);
  }
</style>
