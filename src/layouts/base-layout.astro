---
import "@/styles/global.css";
import Backdrop from "@/components/backdrop.astro";
import Scanlines from "@/components/scanlines.astro";
import Vignette from "@/components/vignette.astro";
import ScrollIndicator from "@/components/scroll-indicator.astro";
import TweaksPanel from "@/components/tweaks-panel.astro";

type App = "menu" | "about" | "work" | "projects" | "blog" | "error";

interface Props {
  title: string;
  description?: string;
  reading?: boolean;
  /** Which "app" is running — drives the per-section theme + boot splash. */
  app?: App;
}

const {
  title,
  description = "Engineering manager, builder, writer.",
  reading = false,
  app = "menu",
} = Astro.props;
const currentPath = Astro.url.pathname;

// Per-app boot-splash + app-bar metadata.
const APPS: Record<App, { file: string; tag: string }> = {
  menu: { file: "MCNEES.OS", tag: "Personal operating system" },
  about: { file: "ABOUT.EXE", tag: "Operator profile" },
  work: { file: "WORK.EXE", tag: "Case studies" },
  projects: { file: "PROJECTS.EXE", tag: "Side-quest builds" },
  blog: { file: "BLOG.EXE", tag: "Transmission log" },
  error: { file: "SIGNAL.LOST", tag: "Connection dropped" },
};
const meta = APPS[app];

// Control-deck nav — one arcade button per app.
const navItems = [
  { label: "MENU", href: "/", match: (p: string) => p === "/" },
  { label: "ABOUT", href: "/about", match: (p: string) => p.startsWith("/about") },
  { label: "WORK", href: "/case-studies", match: (p: string) => p.startsWith("/case-studies") },
  { label: "PROJECTS", href: "/projects", match: (p: string) => p.startsWith("/projects") },
  { label: "BLOG", href: "/blog", match: (p: string) => p.startsWith("/blog") },
];
---
<html lang="en" data-app={app}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=VT323&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body class="arcade" data-reading={reading ? "true" : undefined}>
    <Backdrop />
    <Vignette />
    <Scanlines />
    <ScrollIndicator />

    <!-- ===== CABINET CHROME (fixed beige bezel) ===== -->
    <header class="cab-marquee cab-plastic">
      <span class="cab-speaker" aria-hidden="true"></span>
      <a class="cab-sign" href="/" aria-label="MCNEES Arcade — main menu">
        <span class="cab-title">MCNEES&nbsp;ARCADE</span>
        <span class="cab-subtitle">INSERT COIN · SELECT PROGRAM</span>
      </a>
      <span class="cab-speaker" aria-hidden="true"></span>
    </header>

    <div class="cab-rail cab-rail-l cab-plastic" aria-hidden="true">
      <span class="cab-screw top"></span>
      <span class="cab-screw bottom"></span>
    </div>
    <div class="cab-rail cab-rail-r cab-plastic" aria-hidden="true">
      <span class="cab-screw top"></span>
      <span class="cab-screw bottom"></span>
    </div>

    <div class="cab-glass" aria-hidden="true"></div>

    <!-- Per-app launch splash -->
    <div class="cab-boot" data-boot data-app={app}>
      <div class="cab-boot-inner">
        <div class="cab-boot-app">{meta.file}</div>
        <div class="cab-boot-tag">{meta.tag}</div>
        <div class="cab-boot-bar"><i></i></div>
        <div class="cab-boot-status">LOADING {meta.file}…</div>
      </div>
    </div>

    <footer class="cab-deck cab-plastic">
      <div class="cab-controls" aria-hidden="true">
        <span class="cab-stick">
          <span class="base"></span><span class="shaft"></span><span class="ball"></span>
        </span>
        <span class="cab-abtn red"></span>
        <span class="cab-abtn blue"></span>
      </div>
      <nav class="cab-nav" aria-label="Programs">
        {navItems.map(({ label, href, match }) => (
          <a href={href} class:list={["cab-btn", match(currentPath) && "active"]}>{label}</a>
        ))}
        <button type="button" class="cab-btn" data-comms-open>SOCIAL</button>
      </nav>
      <div class="cab-power">
        <span class="led" aria-hidden="true"></span>
        <span class="pwr-label">SYS ONLINE</span>
        <span class="cab-coin" id="cab-clock">--:--:--</span>
      </div>
    </footer>

    <!-- ===== RUNNING APP ===== -->
    <div class="sw-shell">
      <main class="sw-content sw-page page active">
        {app !== "menu" && (
          <div class="appbar">
            <span class="appbar-dot" aria-hidden="true"></span>
            <span class="appbar-name">{meta.file}</span>
            <span class="appbar-state">● Running</span>
            <a class="appbar-eject" href="/">⏏ Menu</a>
          </div>
        )}
        <slot />
      </main>
    </div>

    <!-- ===== COMMS UPLINK (SOCIAL app) ===== -->
    <div class="cab-comms" data-comms role="dialog" aria-modal="true" aria-label="Comms uplink">
      <div class="cab-comms-card">
        <button type="button" class="cab-comms-close" data-comms-close aria-label="Close">✕</button>
        <h2>COMMS UPLINK</h2>
        <div class="sub">// establish connection</div>
        <div class="cab-comms-links">
          <a href="mailto:mcnees.michael@gmail.com"><span>Email</span><span class="arr">▷</span></a>
          <a href="https://github.com/michaelmcnees" target="_blank" rel="noopener"><span>GitHub</span><span class="arr">▷</span></a>
          <a href="https://gitlab.com/mmcnees" target="_blank" rel="noopener"><span>GitLab</span><span class="arr">▷</span></a>
        </div>
      </div>
    </div>

    <TweaksPanel />

    <script is:inline>
      // ---- Control-deck clock ----
      (function () {
        const el = document.getElementById("cab-clock");
        if (!el) return;
        const pad = (n) => String(n).padStart(2, "0");
        const tick = () => {
          const d = new Date();
          el.textContent = `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
        };
        tick();
        setInterval(tick, 1000);
      })();

      // ---- Boot splash: the per-app "launch" animation ----
      (function () {
        const boot = document.querySelector("[data-boot]");
        if (!boot) return;
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const isMenu = boot.dataset.app === "menu";
        let booted = false;
        try { booted = sessionStorage.getItem("arcade.booted") === "1"; } catch (e) {}

        // Reduced motion, or returning to the menu after first boot → skip.
        if (reduce || (isMenu && booted)) {
          boot.remove();
          return;
        }

        const bar = boot.querySelector(".cab-boot-bar i");
        const dur = isMenu ? 1100 : 650;
        requestAnimationFrame(() => {
          if (bar) {
            bar.style.transition = `width ${dur}ms cubic-bezier(.2,.7,.3,1)`;
            bar.style.width = "100%";
          }
        });
        setTimeout(() => {
          boot.classList.add("done");
          try { sessionStorage.setItem("arcade.booted", "1"); } catch (e) {}
        }, dur + 120);
        setTimeout(() => boot.remove(), dur + 480);
      })();

      // ---- Comms uplink overlay ----
      (function () {
        const modal = document.querySelector("[data-comms]");
        if (!modal) return;
        const open = () => modal.classList.add("open");
        const close = () => modal.classList.remove("open");
        document.querySelectorAll("[data-comms-open]").forEach((b) =>
          b.addEventListener("click", open));
        document.querySelectorAll("[data-comms-close]").forEach((b) =>
          b.addEventListener("click", close));
        modal.addEventListener("click", (e) => { if (e.target === modal) close(); });
        document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });
      })();

      // ---- Konami easter egg (preserved from the original site) ----
      requestIdleCallback(() => {
        const code = [38, 38, 40, 40, 37, 39, 37, 39, 66, 65];
        let pos = 0;
        document.addEventListener("keydown", (e) => {
          if (e.keyCode === code[pos]) {
            pos++;
            if (pos === code.length) {
              pos = 0;
              const overlay = document.createElement("div");
              Object.assign(overlay.style, {
                position: "fixed", inset: "0", zIndex: "9999",
                pointerEvents: "none", opacity: "0",
                background: "repeating-linear-gradient(to bottom, transparent 0 2px, oklch(0 0 0 / 0.08) 2px 4px)",
              });
              document.body.appendChild(overlay);
              overlay.animate([
                { opacity: 0 }, { opacity: 0.15, offset: 0.3 }, { opacity: 0 },
              ], { duration: 2000 }).onfinish = () => overlay.remove();

              const toast = document.createElement("div");
              toast.textContent = "↑↑↓↓←→←→BA · 30 extra lives granted";
              Object.assign(toast.style, {
                position: "fixed", bottom: "calc(var(--deck-h) + 1rem)", left: "50%",
                transform: "translateX(-50%) translateY(1rem)",
                fontFamily: "var(--font-mono)", fontSize: "0.875rem",
                color: "var(--mag-2)", padding: "0.5rem 1rem",
                border: "1px solid var(--mag)",
                borderRadius: "0.5rem", background: "rgba(10,2,32,0.95)",
                zIndex: "10000", opacity: "0", whiteSpace: "nowrap",
                boxShadow: "0 0 14px rgba(255,43,214,0.8)",
              });
              document.body.appendChild(toast);
              toast.animate([
                { opacity: 0, transform: "translateX(-50%) translateY(1rem)" },
                { opacity: 1, transform: "translateX(-50%) translateY(0)", offset: 0.15 },
                { opacity: 1, transform: "translateX(-50%) translateY(0)", offset: 0.7 },
                { opacity: 0, transform: "translateX(-50%) translateY(-0.5rem)" },
              ], { duration: 3000 }).onfinish = () => toast.remove();
            }
          } else {
            pos = e.keyCode === code[0] ? 1 : 0;
          }
        });
      });
    </script>
  </body>
</html>
